# ======================================
# CONFIGURACIÓN NEBULA - VARIABLES DE ENTORNO
# ======================================
# COPIA ESTE ARCHIVO COMO '.env' Y COMPLETA LOS VALORES
# ¡NUNCA SUBAS EL ARCHIVO '.env' REAL A GIT!

# DATABASE
POSTGRES_DB=nebula_db
POSTGRES_USER=nebula_admin
POSTGRES_PASSWORD=cambiar_password_seguro_db

# APPS
WEB_PORT=8080
API_PORT=5000
POSTGRES_PORT=5432

# DOMINIO (Para Nginx y SSL)
DOMAIN_NAME=tu-dominio.com
EMAIL_ADMIN=admin@tu-dominio.com

# MONITORING
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
