# ══════════════════════════════════════════════════════════
# OEDON — Configuration (.env)
# Copy to .env and change ALL values marked CHANGE_ME
# ══════════════════════════════════════════════════════════

# ── Domain ──────────────────────────────────────────────
# Used by: render-nginx.sh, generate_certs.sh, oedon-stats.sh
DOMAIN=oedon.test

# ── Docker ──────────────────────────────────────────────
NETWORK_NAME=oedon-network

# ── Ports ───────────────────────────────────────────────
# Used by: portero, firewall, fail2ban, install.sh
SSH_PORT=2222
HTTP_PORT=80
HTTPS_PORT=443
PORTERO_UDP_PORT=62201

# ── Portero Digital (HMAC port knocking) ────────────────
# Generate: openssl rand -hex 32
PORTERO_SECRET=CHANGE_ME
PORTERO_WINDOW=60
PORTERO_TOLERANCE=30

# ── WordPress / MariaDB ────────────────────────────────
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=123456

# ── SSL ─────────────────────────────────────────────────
SSL_CERT=./config/nginx/ssl/oedon.crt
SSL_KEY=./config/nginx/ssl/oedon.key

# ── Telegram (watchdog + backups) ───────────────────────
TELEGRAM_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME

# ── Watchdog ────────────────────────────────────────────
WATCHDOG_DISK_THRESHOLD=85
WATCHDOG_MEM_THRESHOLD=90
WATCHDOG_CONTAINERS="oedon-proxy oedon-static wordpress-app wordpress-db python-app"
WATCHDOG_COOLDOWN_DIR=/tmp/oedon-watchdog
WATCHDOG_COOLDOWN_MIN=30

# ── Certbot ─────────────────────────────────────────────
CERTBOT_EMAIL=tu_email@ejemplo.com
