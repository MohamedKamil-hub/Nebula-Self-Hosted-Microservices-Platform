# ══════════════════════════════════════════════════════════
# OEDON — Configuration (.env)
# Copy to .env and change ALL values marked CHANGE_ME
# ══════════════════════════════════════════════════════════

# ── Domain ──────────────────────────────────────────────
# Used by: render-nginx.sh, generate_certs.sh, oedon-stats.sh
DOMAIN=CHANGE_ME

# Modes: local | production
APP_ENV=CHANGE_ME


# ── Docker ──────────────────────────────────────────────
NETWORK_NAME=CHANGE_ME

# ── Ports ───────────────────────────────────────────────
# Used by: portero, firewall, fail2ban, install.sh
SSH_PORT=CHANGE_ME
HTTP_PORT=CHANGE_ME
HTTPS_PORT=CHANGE_ME
PORTERO_UDP_PORT=CHANGE_ME

# ── Portero Digital (HMAC port knocking) ────────────────
# Generate: openssl rand -hex 32
PORTERO_SECRET=CHANGE_ME
PORTERO_WINDOW=CHANGE_ME
PORTERO_TOLERANCE=CHANGE_ME

# ── WordPress / MariaDB ────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=CHANGE_ME
MYSQL_USER=CHANGE_ME
MYSQL_PASSWORD=CHANGE_ME

# ── SSL ─────────────────────────────────────────────────
SSL_CERT=CHANGE_ME
SSL_KEY=CHANGE_ME

# ── Telegram (watchdog + backups) ───────────────────────
TELEGRAM_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME

# ── Watchdog ────────────────────────────────────────────
WATCHDOG_DISK_THRESHOLD=CHANGE_ME
WATCHDOG_MEM_THRESHOLD=CHANGE_ME
WATCHDOG_CONTAINERS=CHANGE_ME
WATCHDOG_COOLDOWN_DIR=CHANGE_ME
WATCHDOG_COOLDOWN_MIN=CHANGE_ME

# ── Certbot ─────────────────────────────────────────────
CERTBOT_EMAIL=CHANGE_ME
