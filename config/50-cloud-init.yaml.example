# netplan-config.yaml.example
network:
  version: 2
  ethernets:
    enp0s3:
      dhcp4: true
    enp0s8:
      dhcp4: false
      addresses:
        - 192.168.1.141/24   # <--- Cambia por tu IP estática
      routes:
        - to: default
          via: 192.168.1.1    # <--- Cambia por tu gateway
          metric: 100
      nameservers:
        addresses: [8.8.8.8, 1.1.1.1]
